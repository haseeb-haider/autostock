# Copy to .env for local dev (SQLite is used automatically if DATABASE_URL is unset).
# In production, set these in the Render dashboard.

DATABASE_URL=postgresql://user:pass@your-neon-host/dbname?sslmode=require
ADMIN_TOKEN=pick-a-long-random-string
BUSINESS_NAME=My Bakery

# Optional UI login (leave blank to disable)
APP_USER=
APP_PASS=

# Email (for reorder digests / auto POs). Gmail: use an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
ALERT_EMAIL=you@gmail.com

# Automation tuning
WINDOW_DAYS=30
DEFAULT_LEAD_DAYS=7
SAFETY_DAYS=3
COVER_DAYS=30
AUTO_CREATE_PO=false
AUTO_SEND_PO=false
ENABLE_SCHEDULER=false
